{
  "disable_ai": true,

  "cli_default_open_behavior": "existing_window",
  "proxy": "",
  "project_panel": {
    "dock": "left",
  },

  "agent": {
    "dock": "right",
    "flexible": false,
    "favorite_models": [],
    "model_parameters": [],
  },

  "icon_theme": "Material Icon Theme",

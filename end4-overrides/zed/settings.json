    "show_sign_in": false,
  },

  "edit_predictions": {
    "provider": "none",
  },

  "collaboration_panel": {
    "button": false,
  },

  "theme": {
    "mode": "dark",
    "light": "Noctalia Light",
    "dark": "Noctalia Dark",
  },

  "tab_size": 2,

sort=-time
layer=overlay
icons=0
max-icon-size=64
default-timeout=5000
ignore-timeout=1

width=500
height=300
border-size=2
border-radius=0
padding=15
font=JetBrains Mono Nerd Font 10
format=<b>%s</b>\n%b

background-color=#282828
text-color=#ebdbb2

[urgency=low]
border-color=#458588

[urgency=normal]
border-color=#458588

[urgency=critical]
border-color=#cc241d
default-timeout=0

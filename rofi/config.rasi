configuration {
 modi: "drun";
 font: "BlexMono Nerd Font 10";
 show-icons: false;
 terminal: "kitty";
 drun-display-format: "{name}";
 display-drun: " ";
 timeout {
  action: "kb-cancel";
  delay: 0;
  }
 filebrowser {
  directories-first: true;
  sorting-method: "name";
  }
 }

@theme "~/.config/rofi/dmenu.rasi"
